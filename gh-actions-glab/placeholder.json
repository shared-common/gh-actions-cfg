{
  "notes": [
    "Illustrative examples only.",
    "This file is not consumed by the workflow.",
    "Use gl_forks_ext.json for external targets and gl_forks_int.json for internal targets."
  ],
  "external_example": {
    "version": 1,
    "targets": [
      {
        "target_project_path": "ghgl-forks/mainline/example-project",
        "source_url": "https://gitlab.example.org/group/example-project",
        "branch_rev": "feature/login",
        "branches": [
          { "name": "dev/test", "protected": true, "upstream": false },
          { "name": "fix/bug123", "protected": true, "upstream": true }
        ],
        "tags": [
          { "name": "v1.2.3", "protected": true, "upstream": true },
          { "name": "qa-build-2026-04-05", "protected": false, "upstream": false }
        ]
      }
    ]
  },
  "internal_example": {
    "version": 1,
    "targets": [
      {
        "target_project_path": "glab-forks/system/example-project",
        "source_project_path": "upstream-group/example-project",
        "branch_rev": "feature/login",
        "branches": [
          { "name": "dev/test", "protected": true, "upstream": false },
          { "name": "fix/bug123", "protected": true, "upstream": true }
        ],
        "tags": [
          { "name": "v1.2.3", "protected": true, "upstream": true },
          { "name": "qa-build-2026-04-05", "protected": false, "upstream": false }
        ]
      }
    ]
  }
}
